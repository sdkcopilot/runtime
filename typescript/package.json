{
  "name": "@sdkcopilot/runtime",
  "version": "0.1.3",
  "description": "Shared runtime used by SDKCopilot-generated TypeScript SDKs.",
  "license": "PolyForm-Shield-1.0.0",
  "homepage": "https://sdkcopilot.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdkcopilot/runtime.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/sdkcopilot/runtime/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "lint": "eslint .",
    "prepack": "node ./scripts/sync-license.mjs",
    "prepublishOnly": "pnpm check && pnpm build",
    "release:dry": "npm publish --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  }
}
